            "content": "<!DOCTYPE html>\r\n<html lang=\"ko\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>JS아카이브 | 수학 기출 통합 시스템</title>\r\n    <link rel=\"stylesheet\" as=\"style\" crossorigin href=\"https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css\" />\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\r\n    <style>\r\n        :root {\r\n            --navy:          #07111f;\r\n            --navy-2:        #0c1a2e;\r\n            --blue-main:     #1d4ed8;\r\n            --blue-light:    #60a5fa;\r\n            --blue-pale:     #dbeafe;\r\n            --green-main:    #059669;\r\n            --green-pale:    #d1fae5;\r\n            --gray-muted:    #94a3b8;\r\n            --bg-soft:       #f8fafc;\r\n        }\r\n\r\n        * { box-sizing: border-box; margin: 0; padding: 0; }\r\n        body { font-family: 'Pretendard', sans-serif; background: var(--bg-soft); color: #1e293b; overflow-x: hidden; }\r\n\r\n        header { background: var(--navy); position: sticky; top: 0; z-index: 1000; border-bottom: 1px solid rgba(255,255,255,0.06); }\r\n        .top-nav { max-width: 1200px; margin: 0 auto; height: 56px; display: flex; align-items: center; justify-content: space-between; padding: 0 24px; }\r\n\r\n        .logo { display: flex; align-items: center; gap: 10px; cursor: pointer; }\r\n        .logo-mark { width: 28px; height: 28px; border-radius: 7px; background: var(--blue-main); display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 3px; padding: 5px; }\r\n        .logo-mark div { background: white; border-radius: 1px; }\r\n        .logo-mark div:last-child { background: var(--blue-light); }\r\n        .logo-name { font-size: 17px; font-weight: 800; color: white; letter-spacing: -0.5px; }\r\n        .logo-name em { color: var(--blue-light); font-style: normal; }\r\n\r\n        .grade-nav { display: flex; gap: 2px; }\r\n        .gtab { font-size: 13px; color: rgba(255,255,255,0.38); font-weight: 600; padding: 5px 11px; border-radius: 6px; cursor: pointer; transition: 0.15s; }\r\n        .gtab:hover { color: rgba(255,255,255,0.7); }\r\n        .gtab.active { color: white; background: rgba(255,255,255,0.1); }\r\n\r\n        .nav-count { font-size: 11px; color: rgba(255,255,255,0.35); font-weight: 600; background: rgba(255,255,255,0.07); padding: 4px 12px; border-radius: 20px; }\r\n\r\n        .hero { background: var(--navy); padding: 36px 24px 50px; position: relative; overflow: hidden; }\r\n        .hero-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; }\r\n        .hero-grid-bg {\r\n            position: absolute; inset: 0; opacity: 0.035;\r\n            background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px),\r\n                              linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px);\r\n            background-size: 32px 32px;\r\n        }\r\n        .hero-deco { position: absolute; right: 10%; top: 20px; opacity: 0.06; pointer-events: none; }\r\n        .hero-deco div { color: white; font-size: 22px; font-family: 'Nanum Myeongjo', serif; line-height: 2.2; text-align: right; }\r\n\r\n        .hero-tag { display: inline-flex; align-items: center; gap: 6px; background: rgba(29,78,216,0.2); border: 1px solid rgba(96,165,250,0.2); border-radius: 20px; padding: 4px 12px; margin-bottom: 16px; }\r\n        .tag-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--blue-light); }\r\n        .hero-tag span { font-size: 11px; font-weight: 700; color: #93c5fd; letter-spacing: 0.8px; text-transform: uppercase; }\r\n\r\n        .hero-title { font-size: 30px; font-weight: 800; color: white; line-height: 1.25; letter-spacing: -0.8px; margin-bottom: 7px; word-break: keep-all; }\r\n        .hero-title em { color: var(--blue-light); font-style: normal; }\r\n        .hero-desc { font-size: 13px; color: rgba(255,255,255,0.38); line-height: 1.6; }\r\n\r\n        .stat-pills { display: flex; gap: 10px; flex-shrink: 0; }\r\n        .stat-pill { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 12px; padding: 16px 22px; text-align: center; min-width: 84px; }\r\n        .stat-n { font-size: 26px; font-weight: 800; color: var(--blue-light); line-height: 1; font-variant-numeric: tabular-nums; }\r\n        .stat-l { font-size: 11px; color: rgba(255,255,255,0.35); font-weight: 600; margin-top: 5px; white-space: nowrap; }\r\n\r\n        .filter-band { background: white; border-bottom: 1px solid #e2e8f0; position: sticky; top: 56px; z-index: 900; }\r\n        .filter-inner { max-width: 1200px; margin: 0 auto; padding: 10px 24px; display: flex; align-items: center; gap: 10px; }\r\n\r\n        .fb-search { flex: 1; position: relative; }\r\n        .fb-search input {\r\n            width: 100%; background: #f8fafc; border: 1px solid #e2e8f0;\r\n            border-radius: 8px; padding: 9px 14px 9px 36px;\r\n            font-size: 13px; color: #1e293b; font-family: inherit; outline: none;\r\n        }\r\n        .fb-search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); font-size: 13px; color: #94a3b8; pointer-events: none; }\r\n\r\n        .fb-mixer {\r\n            display: flex; align-items: center; gap: 7px;\r\n            background: var(--blue-main); color: white; border: none;\r\n            border-radius: 8px; padding: 9px 18px; font-size: 13px;\r\n            font-weight: 700; font-family: inherit; cursor: pointer;\r\n            white-space: nowrap; flex-shrink: 0;\r\n        }\r\n\r\n        .content-wrap { max-width: 1200px; margin: 0 auto; padding: 28px 24px 60px; }\r\n        .sec-block { margin-bottom: 32px; }\r\n        .sec-header { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }\r\n        .sec-badge { font-size: 12px; font-weight: 800; color: white; padding: 4px 12px; border-radius: 6px; flex-shrink: 0; }\r\n        .sec-badge.engine { background: var(--blue-main); }\r\n        .sec-line  { flex: 1; height: 0.5px; background: #e2e8f0; }\r\n\r\n        .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }\r\n\r\n        /* 카드 레이아웃 재구성: 수직 정렬 순서 고정 */\r\n        .exam-card { background: white; border: 1px solid #f1f5f9; border-radius: 14px; overflow: hidden; display: flex; flex-direction: column; transition: 0.2s; }\r\n        .exam-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.06); border-color: #e2e8f0; }\r\n        .card-top { height: 4px; background: var(--blue-main); }\r\n        .card-top.green { background: var(--green-main); }\r\n        \r\n        .card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 6px; }\r\n        .card-school { font-size: 18px; font-weight: 800; color: #1e293b; letter-spacing: -0.5px; }\r\n        .card-exam-type { font-size: 14px; font-weight: 700; color: #475569; }\r\n        .card-engine-tag { align-self: flex-start; margin: 2px 0; }\r\n        .card-grade-info { font-size: 13px; font-weight: 700; color: #94a3b8; }\r\n\r\n        .badge { font-size: 10px; font-weight: 800; padding: 4px 10px; border-radius: 6px; display: inline-block; }\r\n        .badge.blue  { background: var(--blue-pale); color: var(--blue-main); }\r\n        .badge.green { background: var(--green-pale); color: var(--green-main); }\r\n\r\n        .card-actions { border-top: 1px solid #f1f5f9; display: flex; background: #fcfdfe; }\r\n        .action-btn { flex: 1; padding: 14px 0; text-align: center; font-size: 12px; font-weight: 700; color: #64748b; cursor: pointer; transition: 0.15s; }\r\n        .action-btn + .action-btn { border-left: 1px solid #f1f5f9; }\r\n        .action-btn:hover { background: #f1f5f9; color: var(--blue-main); }\r\n        .action-btn.sole { color: var(--green-main); }\r\n\r\n        .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 2000; align-items: center; justify-content: center; }\r\n        .modal-overlay.open { display: flex; }\r\n        .modal-box { background: white; border-radius: 20px; padding: 36px 40px; width: 360px; text-align: center; }\r\n        .qpp-btns { display: flex; gap: 14px; justify-content: center; margin-top: 20px; }\r\n        .qpp-opt { flex: 1; padding: 20px 0; border: 2px solid #e2e8f0; border-radius: 14px; cursor: pointer; font-size: 28px; font-weight: 800; }\r\n        .qpp-opt:hover { border-color: var(--blue-main); color: var(--blue-main); }\r\n    </style>\r\n</head>\r\n<body>\r\n\r\n<div class=\"modal-overlay\" id=\"qppModal\">\r\n    <div class=\"modal-box\">\r\n        <div style=\"font-size:18px; font-weight:800;\">시험지 출력 형식</div>\r\n        <div class=\"qpp-btns\">\r\n            <div class=\"qpp-opt\" onclick=\"confirmQpp(4)\">4<span style=\"display:block; font-size:11px;\">2x2 배열</span></div>\r\n            <div class=\"qpp-opt\" onclick=\"confirmQpp(6)\">6<span style=\"display:block; font-size:11px;\">2x3 배열</span></div>\r\n        </div>\r\n        <button onclick=\"closeModal()\" style=\"margin-top:20px; border:none; background:none; color:#94a3b8; cursor:pointer;\">취소</button>\r\n    </div>\r\n</div>\r\n\r\n<header>\r\n    <div class=\"top-nav\">\r\n        <div class=\"logo\" onclick=\"resetView()\">\r\n            <div class=\"logo-mark\"><div></div><div></div><div></div><div></div></div>\r\n            <span class=\"logo-name\"><em>JS</em>아카이브</span>\r\n        </div>\r\n        <nav class=\"grade-nav\" id=\"gradeBar\">\r\n            <span class=\"gtab\" data-grade=\"고3\">고3</span>\r\n            <span class=\"gtab\" data-grade=\"고2\">고2</span>\r\n            <span class=\"gtab\" data-grade=\"고1\">고1</span>\r\n            <span class=\"gtab\" data-grade=\"중3\">중3</span>\r\n            <span class=\"gtab\" data-grade=\"중2\">중2</span>\r\n            <span class=\"gtab active\" data-grade=\"\">전체</span>\r\n        </nav>\r\n        <span class=\"nav-count\" id=\"navCount\">0개</span>\r\n    </div>\r\n</header>\r\n\r\n<div class=\"hero\">\r\n    <div class=\"hero-grid-bg\"></div>\r\n    <div class=\"hero-inner\">\r\n        <div>\r\n            <div class=\"hero-tag\"><div class=\"tag-dot\"></div><span>수학 기출 아카이브</span></div>\r\n            <div class=\"hero-title\">학교별 기출 & 변형<br><em>통합 출제 시스템</em></div>\r\n            <div class=\"hero-desc\">시험지 · 해설지 · 정답표를 한 번에<br>엔진 렌더링 + PDF 기출 통합 관리</div>\r\n        </div>\r\n        <div class=\"stat-pills\">\r\n            <div class=\"stat-pill\"><div class=\"stat-n\" id=\"stat-total\">0</div><div class=\"stat-l\">총 시험지</div></div>\r\n            <div class=\"stat-pill\"><div class=\"stat-n\" id=\"stat-pdf\">0</div><div class=\"stat-l\">PDF 기출</div></div>\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n<div class=\"filter-band\">\r\n    <div class=\"filter-inner\">\r\n        <div class=\"fb-search\">\r\n            <i class=\"fa-solid fa-magnifying-glass fb-search-icon\"></i>\r\n            <input type=\"text\" id=\"searchInput\" placeholder=\"학교명, 과목 검색…\">\r\n        </div>\r\n        <button class=\"fb-mixer\" onclick=\"location.href='mixer.html'\">믹서 출제</button>\r\n    </div>\r\n</div>\r\n\r\n<div class=\"content-wrap\">\r\n    <div id=\"featured-section\"></div>\r\n    <div id=\"full-section\" style=\"display:none;\">\r\n        <div id=\"full-grid\" class=\"card-grid\"></div>\r\n    </div>\r\n</div>\r\n\r\n<script>\r\nlet engineDB = { exams: [] };\r\nlet archiveDB = { files: [] };\r\nlet selectedGrade = '';\r\n\r\nasync function init() {\r\n    await new Promise(res => {\r\n        const s = document.createElement('script');\r\n        s.src = 'db.js?v=' + Date.now();\r\n        s.onload = () => { engineDB = window.mainDB || window.db || { exams: [] }; res(); };\r\n        s.onerror = () => res();\r\n        document.body.appendChild(s);\r\n    });\r\n\r\n    try {\r\n        const r = await fetch('./data/catalog.json?v=' + Date.now());\r\n        if (r.ok) archiveDB = await r.json();\r\n    } catch (e) {}\r\n\r\n    updateStats();\r\n    initGradeBar();\r\n    renderFeatured();\r\n    document.getElementById('searchInput').addEventListener('input', onFilterChange);\r\n}\r\n\r\nfunction updateStats() {\r\n    const total = engineDB.exams.length + (archiveDB.files?.length || 0);\r\n    document.getElementById('stat-total').innerText = total;\r\n    document.getElementById('stat-pdf').innerText = archiveDB.files?.length || 0;\r\n    document.getElementById('navCount').innerText = `시험지 ${total}개`;\r\n}\r\n\r\nfunction initGradeBar() {\r\n    document.querySelectorAll('.gtab').forEach(tab => {\r\n        tab.onclick = () => {\r\n            document.querySelectorAll('.gtab').forEach(t => t.classList.remove('active'));\r\n            tab.classList.add('active');\r\n            selectedGrade = tab.dataset.grade;\r\n            onFilterChange();\r\n        };\r\n    });\r\n}\r\n\r\nfunction onFilterChange() {\r\n    const keyword = document.getElementById('searchInput').value.trim();\r\n    if (keyword || selectedGrade) {\r\n        document.getElementById('featured-section').style.display = 'none';\r\n        document.getElementById('full-section').style.display = 'block';\r\n        renderFullList(keyword);\r\n    } else {\r\n        document.getElementById('featured-section').style.display = 'block';\r\n        document.getElementById('full-section').style.display = 'none';\r\n        renderFeatured();\r\n    }\r\n}\r\n\r\nfunction buildCard(ex) {\r\n    const isArchive = ex.url || ex.fileName;\r\n    const card = document.createElement('div');\r\n    card.className = 'exam-card';\r\n\r\n    const school = ex.school || '학교 미상';\r\n    const examType = ex.semester ? `${ex.semester}학기 ${ex.examType === 'mid' ? '중간' : '기말'}` : (ex.exam || '기출 시험');\r\n    const engineTag = isArchive ? '<span class=\"badge green\">PDF기출</span>' : '<span class=\"badge blue\">엔진기출</span>';\r\n    const grade = ex.grade || '전학년';\r\n\r\n    card.innerHTML = `\r\n        <div class=\"card-top ${isArchive ? 'green' : ''}\"></div>\r\n        <div class=\"card-body\">\r\n            <div class=\"card-school\">${school}</div>\r\n            <div class=\"card-exam-type\">${examType}</div>\r\n            <div class=\"card-engine-tag\">${engineTag}</div>\r\n            <div class=\"card-grade-info\">${grade}</div>\r\n        </div>\r\n        <div class=\"card-actions\">\r\n            ${isArchive ? \r\n                `<div class=\"action-btn sole\" onclick=\"openEngine('${ex.url || ex.fileName}', 'pdf', '${school}${grade}')\">PDF 열기</div>` :\r\n                `<div class=\"action-btn\" onclick=\"openEngine('${ex.file}', 'exam', '${school}${grade}')\">시험지</div>\r\n                 <div class=\"action-btn\" onclick=\"openEngine('${ex.file}', 'sol', '${school}${grade}')\">해설지</div>\r\n                 <div class=\"action-btn\" onclick=\"openEngine('${ex.file}', 'ans', '${school}${grade}')\">정답표</div>`\r\n            }\r\n        </div>`;\r\n    return card;\r\n}\r\n\r\nlet _pendingFile = '';\r\nlet _pendingTitle = '';\r\n\r\nfunction openEngine(file, mode, title) {\r\n    if (mode === 'pdf') {\r\n        location.href = `engine.html?mode=pdf&file=${encodeURIComponent(file)}&title=${encodeURIComponent(title)}`;\r\n        return;\r\n    }\r\n    if (mode === 'exam') {\r\n        _pendingFile = file; _pendingTitle = title;\r\n        document.getElementById('qppModal').classList.add('open');\r\n        return;\r\n    }\r\n    location.href = `engine.html?mode=${mode}&data=exams/${file}&title=${encodeURIComponent(title)}`;\r\n}\r\n\r\nfunction confirmQpp(qpp) {\r\n    location.href = `engine.html?mode=exam&qpp=${qpp}&data=exams/${_pendingFile}&title=${encodeURIComponent(_pendingTitle)}`;\r\n}\r\n\r\nfunction closeModal() { document.getElementById('qppModal').classList.remove('open'); }\r\n\r\nfunction renderFeatured() {\r\n    const container = document.getElementById('featured-section');\r\n    container.innerHTML = '';\r\n    const section = document.createElement('div');\r\n    section.className = 'sec-block';\r\n    section.innerHTML = `<div class=\"sec-header\"><span class=\"sec-badge engine\">최신 기출</span><div class=\"sec-line\"></div></div><div class=\"card-grid\" id=\"f-grid\"></div>`;\r\n    container.appendChild(section);\r\n    const grid = section.querySelector('#f-grid');\r\n    engineDB.exams.slice(0, 4).forEach(ex => grid.appendChild(buildCard(ex)));\r\n}\r\n\r\nfunction renderFullList(keyword) {\r\n    const grid = document.getElementById('full-grid');\r\n    grid.innerHTML = '';\r\n    const filtered = engineDB.exams.filter(ex => \r\n        (!selectedGrade || ex.grade === selectedGrade) &&\r\n        (!keyword || ex.school.includes(keyword))\r\n    );\r\n    filtered.forEach(ex => grid.appendChild(buildCard(ex)));\r\n}\r\n\r\nfunction resetView() { location.reload(); }\r\nwindow.onload = init;\r\n</script>\r\n</body>\r\n</html>"
        }
    ]
}