            "date": 1776071312496,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"ko\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <title>JS아카이브 엔진</title>\r\n    <script>\r\n        window.MathJax = {\r\n            tex: {\r\n                inlineMath: [['$', '$']],\r\n                displayMath: [['$$', '$$']],\r\n                packages: {'[+]': ['ams', 'boldsymbol']}\r\n            },\r\n            options: { enableMenu: false },\r\n            startup: { typeset: false }\r\n        };\r\n    </script>\r\n    <script id=\"MathJax-script\" async src=\"https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js\"></script>\r\n    <style>\r\n        @import url('https://fonts.googleapis.com/css2?family=Nanum+Myeongjo:wght@400;700;800&display=swap');\r\n        @page { size: A4; margin: 0; }\r\n\r\n        body {\r\n            margin: 0;\r\n            font-family: 'Nanum Myeongjo', serif;\r\n            font-size: 9.5pt;\r\n            background: #f1f5f9;\r\n            padding-top: 54px;\r\n            color: #000;\r\n        }\r\n\r\n        #mode-ctrl {\r\n            position: fixed; top: 0; left: 0; width: 100%; height: 56px;\r\n            background: #0f172a; display: flex; justify-content: space-between;\r\n            align-items: center; padding: 0 24px; z-index: 1000;\r\n            box-sizing: border-box; border-bottom: 1px solid rgba(255,255,255,0.08);\r\n            gap: 16px;\r\n        }\r\n        #ctrl-title {\r\n            font-size: 14px; font-weight: 800; color: white;\r\n            white-space: nowrap; letter-spacing: -0.3px;\r\n            flex-shrink: 0;\r\n        }\r\n        .mode-tabs {\r\n            display: flex; gap: 4px;\r\n            background: rgba(255,255,255,0.07);\r\n            padding: 4px; border-radius: 10px;\r\n            flex-shrink: 0;\r\n        }\r\n        .mode-tab {\r\n            padding: 6px 16px; border-radius: 7px;\r\n            font-size: 12px; font-weight: 700;\r\n            cursor: pointer; border: none;\r\n            background: transparent; color: rgba(255,255,255,0.5);\r\n            transition: 0.18s; font-family: inherit;\r\n            letter-spacing: -0.2px;\r\n        }\r\n        .mode-tab:hover { color: white; background: rgba(255,255,255,0.1); }\r\n        .mode-tab.active {\r\n            background: white; color: #0f172a;\r\n            box-shadow: 0 1px 4px rgba(0,0,0,0.25);\r\n        }\r\n        .ctrl-right { display: flex; gap: 8px; flex-shrink: 0; }\r\n        .print-btn {\r\n            padding: 7px 16px; border: none; border-radius: 7px;\r\n            font-family: inherit; font-weight: 700; font-size: 12px;\r\n            cursor: pointer; transition: 0.15s;\r\n        }\r\n        .print-btn.primary { background: #378ADD; color: white; }\r\n        .print-btn.primary:hover { background: #2e73c4; }\r\n        .print-btn.ghost { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); }\r\n        .print-btn.ghost:hover { background: rgba(255,255,255,0.18); color: white; }\r\n\r\n        #print-area {\r\n            display: none; flex-direction: column;\r\n            align-items: center; gap: 20px; padding: 20px 0;\r\n        }\r\n\r\n        .page {\r\n            width: 210mm; height: 297mm;\r\n            background: white; box-shadow: 0 0 10px rgba(0,0,0,0.1);\r\n            padding: 15mm; box-sizing: border-box;\r\n            display: flex; flex-direction: column;\r\n            overflow: hidden;\r\n        }\r\n\r\n        @media print {\r\n            body { padding-top: 0; background: white; }\r\n            #mode-ctrl { display: none; }\r\n            #print-area { display: flex !important; gap: 0; padding: 0; }\r\n            .page { box-shadow: none; page-break-after: always; }\r\n            #pdf-container { display: block !important; position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999; }\r\n            body:not(.mode-pdf) #pdf-container { display: none !important; }\r\n        }\r\n\r\n        .page-header {\r\n            display: flex; justify-content: space-between;\r\n            border-bottom: 2px solid #000;\r\n            padding-bottom: 5px; margin-bottom: 12px;\r\n            font-weight: bold; flex-shrink: 0;\r\n        }\r\n\r\n        #pdf-container { display: none; width: 100%; height: calc(100vh - 54px); }\r\n        #pdf-viewer { width: 100%; height: 100%; border: none; }\r\n\r\n        .grid-container {\r\n            flex: 1; display: grid;\r\n            grid-template-columns: 1fr 1fr;\r\n            position: relative; overflow: hidden;\r\n        }\r\n        .grid-container::after {\r\n            content: ''; position: absolute;\r\n            left: 50%; top: 0; bottom: 0;\r\n            width: 1px; background: #000;\r\n        }\r\n        .grid-col {\r\n            display: flex; flex-direction: column;\r\n            padding: 0 12px; overflow: hidden;\r\n        }\r\n\r\n        /* 문항 박스 스타일 */\r\n        .q-box {\r\n            flex: 1;\r\n            padding: 10px 0;\r\n            border-bottom: 0.5px solid #ccc;\r\n            overflow: hidden;\r\n            display: flex;\r\n            flex-direction: column;\r\n        }\r\n        .q-box:last-child { border-bottom: none; }\r\n        .q-num { font-weight: bold; font-size: 11pt; margin-bottom: 4px; flex-shrink: 0; }\r\n        \r\n        /* 데이터 내부 .box 스타일 추가 */\r\n        .box {\r\n            border: 1px solid #ccc;\r\n            border-radius: 4px;\r\n            padding: 8px 10px;\r\n            margin: 6px 0;\r\n            background: #f9f9f9;\r\n            font-size: 9pt;\r\n            line-height: 1.5;\r\n        }\r\n\r\n        .answer-box {\r\n            flex: 1;\r\n            border: 1px dashed #bbb;\r\n            margin-top: 8px; background: #fafafa;\r\n        }\r\n        .choices { margin-top: 6px; line-height: 2; }\r\n\r\n        .sol-box {\r\n            padding: 8px 0;\r\n            border-bottom: 0.5px solid #eee;\r\n            width: 100%;\r\n        }\r\n        .sol-box:last-child { border-bottom: none; }\r\n        .sol-step {\r\n            padding-left: 8px;\r\n            border-left: 2px solid #e2e8f0;\r\n            margin-bottom: 4px; font-size: 9pt;\r\n        }\r\n\r\n        .ans-grid {\r\n            display: flex;\r\n            flex-direction: column;\r\n            gap: 10px; margin-top: 10px;\r\n        }\r\n        .ans-cell {\r\n            padding: 8px;\r\n            display: flex; align-items: flex-start; gap: 8px;\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n\r\n    <div id=\"mode-ctrl\">\r\n        <span id=\"ctrl-title\">JS아카이브</span>\r\n        <div class=\"mode-tabs\" id=\"modeTabs\">\r\n            <button class=\"mode-tab\" data-mode=\"exam\" onclick=\"switchMode('exam')\">시험지</button>\r\n            <button class=\"mode-tab\" data-mode=\"sol\"  onclick=\"switchMode('sol')\">해설지</button>\r\n            <button class=\"mode-tab\" data-mode=\"ans\"  onclick=\"switchMode('ans')\">정답표</button>\r\n        </div>\r\n        <div class=\"ctrl-right\">\r\n            <button class=\"print-btn primary\" onclick=\"window.print()\">🖨 인쇄</button>\r\n            <button class=\"print-btn ghost\"   onclick=\"history.back()\">← 목록</button>\r\n        </div>\r\n    </div>\r\n\r\n    <div id=\"pdf-container\">\r\n        <iframe id=\"pdf-viewer\" src=\"\"></iframe>\r\n    </div>\r\n\r\n    <div id=\"print-area\"></div>\r\n    <div id=\"staging\" style=\"position:absolute;top:-9999px;left:0;visibility:hidden;width:85mm;\"></div>\r\n\r\n<script>\r\nconst AppState = { title: 'JS아카이브', data: [], mode: 'exam', qpp: 4 };\r\nlet pageCount = 0;\r\n\r\nasync function loadData(dataUrl) {\r\n    if (dataUrl === 'mixed') {\r\n        const raw = sessionStorage.getItem('mixedQuestions');\r\n        return raw ? JSON.parse(raw) : [];\r\n    }\r\n    return new Promise(res => {\r\n        const oldScript = document.getElementById('data-script');\r\n        if (oldScript) oldScript.remove();\r\n        \r\n        delete window.questionBank;\r\n        const s = document.createElement('script');\r\n        s.id = 'data-script';\r\n        s.src = dataUrl + '?v=' + Date.now();\r\n        s.onload = () => {\r\n            const qb = window.questionBank;\r\n            const data = Array.isArray(qb) ? qb : (qb?.questions || qb?.problems || []);\r\n            res(data);\r\n        };\r\n        s.onerror = () => res([]);\r\n        document.body.appendChild(s);\r\n    });\r\n}\r\n\r\nasync function init() {\r\n    const p = new URLSearchParams(window.location.search);\r\n    AppState.mode  = p.get('mode')  || 'exam';\r\n    AppState.title = p.get('title') || 'JS아카이브 기출';\r\n    \r\n    const rawQpp = parseInt(p.get('qpp'));\r\n    AppState.qpp = isNaN(rawQpp) ? 4 : Math.max(2, Math.min(8, rawQpp));\r\n    AppState.data_url = p.get('data') || '';\r\n\r\n    const file = p.get('file');\r\n    const dataUrl = AppState.data_url;\r\n\r\n    document.getElementById('ctrl-title').innerText = AppState.title;\r\n\r\n    if (AppState.mode === 'pdf' && file) {\r\n        document.body.classList.add('mode-pdf');\r\n        document.getElementById('modeTabs').style.display = 'none';\r\n        document.getElementById('pdf-container').style.display = 'block';\r\n        document.getElementById('pdf-viewer').src = file;\r\n        return;\r\n    }\r\n\r\n    updateTabs(AppState.mode);\r\n    document.getElementById('print-area').style.display = 'flex';\r\n\r\n    if (dataUrl) {\r\n        AppState.data = await loadData(dataUrl);\r\n        if (AppState.data.length > 0) await renderEngine();\r\n    }\r\n}\r\n\r\nfunction updateTabs(mode) {\r\n    document.querySelectorAll('.mode-tab').forEach(btn => {\r\n        btn.classList.toggle('active', btn.dataset.mode === mode);\r\n    });\r\n}\r\n\r\nfunction switchMode(mode) {\r\n    if (mode === AppState.mode) return;\r\n    const qpp = (mode === 'exam') ? AppState.qpp : 4;\r\n    const url = new URL(window.location.href);\r\n    url.searchParams.set('mode', mode);\r\n    url.searchParams.set('qpp', qpp);\r\n    window.location.href = url.toString();\r\n}\r\n\r\nasync function renderEngine() {\r\n    const area = document.getElementById('print-area');\r\n    area.innerHTML = '';\r\n    pageCount = 0;\r\n\r\n    if      (AppState.mode === 'ans') renderAnsGrid(area, AppState.data);\r\n    else if (AppState.mode === 'sol') await renderSol(area, AppState.data);\r\n    else                               await renderExam(area, AppState.data);\r\n}\r\n\r\nasync function renderExam(area, bank) {\r\n    const perCol  = Math.ceil(AppState.qpp / 2);\r\n    const staging = document.getElementById('staging');\r\n    staging.style.width = '85mm';\r\n    staging.innerHTML = '';\r\n\r\n    const boxes = bank.map((q, i) => {\r\n        const el = document.createElement('div');\r\n        el.className = 'q-box';\r\n        el.innerHTML = buildExamBox(q, i);\r\n        staging.appendChild(el);\r\n        return el;\r\n    });\r\n\r\n    if (window.MathJax?.typesetPromise) await MathJax.typesetPromise([staging]);\r\n    await raf();\r\n\r\n    for (let start = 0; start < boxes.length; start += AppState.qpp) {\r\n        const chunk = boxes.slice(start, start + AppState.qpp);\r\n        const page  = makePage(area, 'exam');\r\n        chunk.slice(0, perCol).forEach(el => page.cols[0].appendChild(el.cloneNode(true)));\r\n        chunk.slice(perCol).forEach(el   => page.cols[1].appendChild(el.cloneNode(true)));\r\n    }\r\n}\r\n\r\nfunction buildExamBox(q, i) {\r\n    const circled = ['①','②','③','④','⑤'];\r\n    const isMultipleChoice = Array.isArray(q.choices) && \r\n                             q.choices.length > 0 && \r\n                             q.choices[0] !== \"주관식\" && \r\n                             q.choices.some(c => String(c).trim() !== \"\");\r\n                             \r\n    const choicesHTML = isMultipleChoice\r\n        ? `<div class=\"choices\">${q.choices.map((c, ci) =>\r\n              `<div>${circled[ci] || (ci+1)+')'} ${wrapLatex(String(c))}</div>`).join('')}</div>`\r\n        : `<div class=\"answer-box\"></div>`;\r\n    return `<div class=\"q-num\">${i + 1}.</div><div>${wrapLatex(q.content || q.question || '')}</div>${choicesHTML}`;\r\n}\r\n\r\nasync function renderSol(area, bank) {\r\n    const staging = document.getElementById('staging');\r\n    staging.style.width = '85mm';\r\n    staging.innerHTML = '';\r\n\r\n    const boxes = bank.map((q, i) => {\r\n        const el = document.createElement('div');\r\n        el.className = 'sol-box';\r\n        el.innerHTML = buildSolBox(q, i);\r\n        staging.appendChild(el);\r\n        return el;\r\n    });\r\n\r\n    if (window.MathJax?.typesetPromise) await MathJax.typesetPromise([staging]);\r\n    await raf();\r\n\r\n    let p = makePage(area, 'sol');\r\n    const headerEl = p.page.querySelector('.page-header');\r\n    const headerH  = headerEl?.getBoundingClientRect().height || 40;\r\n    const PAGE_H   = 297 * 3.7795 - 15 * 2 * 3.7795 - headerH - 20; \r\n    \r\n    let curColH = 0;\r\n    let colIdx = 0;\r\n\r\n    for (const el of boxes) {\r\n        const h = el.getBoundingClientRect().height;\r\n        \r\n        if (curColH + h > PAGE_H) {\r\n            if (colIdx === 0) {\r\n                colIdx = 1;\r\n                curColH = 0;\r\n            } else {\r\n                p = makePage(area, 'sol');\r\n                colIdx = 0;\r\n                curColH = 0;\r\n            }\r\n        }\r\n        p.cols[colIdx].appendChild(el.cloneNode(true));\r\n        curColH += h;\r\n    }\r\n}\r\n\r\nfunction buildSolBox(q, i) {\r\n    let solHTML;\r\n    if (q.solution_steps?.length) {\r\n        solHTML = q.solution_steps.map((s, si) =>\r\n            `<div class=\"sol-step\"><b>[${si+1}단계]</b> ${wrapLatex(stripCite(s).replace(/\\n/g, '<br>'))}</div>`\r\n        ).join('');\r\n    } else if (q.solution) {\r\n        // \\\\\\\\ 기준으로 줄 분리하여 각각 수식 처리 (인라인 math 개행 제한 해결)\r\n        const lines = stripCite(q.solution).split(/\\\\\\\\/);\r\n        solHTML = lines.map(line =>\r\n            `<div class=\"sol-step\">${wrapLatex(line.trim().replace(/\\n/g, '<br>'))}</div>`\r\n        ).join('');\r\n    } else {\r\n        solHTML = `<span style=\"color:#94a3b8;font-size:8pt;\">해설 없음</span>`;\r\n    }\r\n    return `\r\n        <div class=\"q-num\" style=\"margin-bottom:4px;\">${i+1}.\r\n            <span style=\"font-size:9pt;font-weight:normal;\">\r\n                ${wrapLatex(q.content || q.question || '')}\r\n            </span>\r\n        </div>\r\n        <div style=\"font-size:9pt;\">${solHTML}</div>`;\r\n}\r\n\r\nfunction renderAnsGrid(area, bank) {\r\n    const p = makePage(area, 'ans');\r\n    const grid = document.createElement('div');\r\n    grid.className = 'ans-grid';\r\n    bank.forEach((q, i) => {\r\n        const cell = document.createElement('div');\r\n        cell.className = 'ans-cell';\r\n        cell.innerHTML = `<b style=\"font-size:11pt;min-width:40px;\">${i+1}.</b>\r\n                          <span style=\"font-size:11pt;\">${wrapLatex(String(q.answer ?? '–'))}</span>`;\r\n        grid.appendChild(cell);\r\n    });\r\n    p.body.appendChild(grid);\r\n    if (window.MathJax?.typesetPromise) MathJax.typesetPromise([p.body]);\r\n}\r\n\r\nfunction makePage(area, type) {\r\n    pageCount++;\r\n    const page = document.createElement('div');\r\n    page.className = 'page';\r\n    const header = document.createElement('div');\r\n    header.className = 'page-header';\r\n    header.innerHTML = `<span>${AppState.title}</span><span>- ${pageCount} -</span>`;\r\n    page.appendChild(header);\r\n\r\n    if (type === 'ans') {\r\n        const body = document.createElement('div');\r\n        body.style.flex = '1';\r\n        page.appendChild(body);\r\n        area.appendChild(page);\r\n        return { page, body };\r\n    }\r\n\r\n    const grid  = document.createElement('div');\r\n    grid.className = 'grid-container';\r\n    const left  = document.createElement('div');\r\n    left.className = 'grid-col';\r\n    const right = document.createElement('div');\r\n    right.className = 'grid-col';\r\n    grid.appendChild(left);\r\n    grid.appendChild(right);\r\n    page.appendChild(grid);\r\n    area.appendChild(page);\r\n    return { page, cols: [left, right] };\r\n}\r\n\r\nfunction wrapLatex(text) {\r\n    if (!text) return text;\r\n    if (text.includes('$')) return text;\r\n    if (text.includes('\\\\')) return `$${text}$`;\r\n    return text;\r\n}\r\n\r\nfunction stripCite(text) {\r\n    if (!text) return text;\r\n    // 인용 패턴 및 대괄호 쌍(예: 【...】, [...]) 제거 로직 업데이트\r\n    return text.replace(/【[^】]*】/g, '').replace(/\\[[^\\]]*\\]/g, '').trim();\r\n}\r\n\r\nfunction raf() { return new Promise(r => requestAnimationFrame(r)); }\r\nwindow.onload = init;\r\n</script>\r\n</body>\r\n</html>"
        }
    ]
}