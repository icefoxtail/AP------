{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JS Archive Tag Enrichment Report",
  "type": "object",
  "required": ["generatedAt", "source", "totals"],
  "properties": {
    "generatedAt": { "type": "string" },
    "source": { "type": "string" },
    "totals": { "type": "object" },
    "filters": { "type": "object" },
    "items": { "type": "array" },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
